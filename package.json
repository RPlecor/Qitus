    "validate:dossier-ec": "tsx scripts/validate-dossier-ec.ts",
    "validate:dossier-ec-end-user": "playwright test -c playwright.config.ts e2e/dossier-ec-end-user.pw.ts",
    "validate:production-config": "tsx scripts/validate-production-config.ts",

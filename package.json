    "validate:privacy": "tsx scripts/validate-privacy.ts",
    "validate:privacy-export": "tsx scripts/validate-privacy-export.ts",
    "validate:privacy-redaction": "tsx scripts/validate-privacy-redaction.ts",
    "validate:chat-billing": "tsx scripts/validate-chat-billing.ts",

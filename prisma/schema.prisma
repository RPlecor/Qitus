}

model BankConnection {
  id                   String               @id @default(cuid())
  companyId            String
  company              Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  provider             OpenBankingProvider
  providerConnectionId String
  status               BankConnectionStatus @default(ACTIVE)
  consentExpiresAt     DateTime?
  lastSyncedAt         DateTime?
  metadataJson         Json?
  accounts             BankFeedAccount[]
  syncEvents           BankFeedSyncEvent[]
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  @@unique([companyId, provider, providerConnectionId])
  @@index([companyId, status])
  @@index([consentExpiresAt])
}

model BankFeedAccount {
  id                String         @id @default(cuid())
  companyId         String
  company           Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  bankConnectionId  String
  bankConnection    BankConnection @relation(fields: [bankConnectionId], references: [id], onDelete: Cascade)
  providerAccountId String
  ibanMasked        String?
  name              String
  currency          String         @default("EUR")
  status            String         @default("ACTIVE")
  metadataJson      Json?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@unique([bankConnectionId, providerAccountId])
  @@index([companyId, status])
}

model BankFeedSyncEvent {
  id               String             @id @default(cuid())
  companyId        String
  company          Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  fiscalYearId     String?
  fiscalYear       FiscalYear?        @relation(fields: [fiscalYearId], references: [id], onDelete: SetNull)
  bankConnectionId String?
  bankConnection   BankConnection?    @relation(fields: [bankConnectionId], references: [id], onDelete: SetNull)
  status           BankFeedSyncStatus
  startedAt        DateTime           @default(now())
  finishedAt       DateTime?
  errorCode        String?
  errorMessage     String?
  transactionsFetched  Int            @default(0)
  transactionsImported Int            @default(0)
  metadataJson     Json?

  @@index([companyId, fiscalYearId, startedAt])
  @@index([bankConnectionId])
  @@index([status])
}

model Attachment {
  id                String           @id @default(cuid())
  companyId         String
  company           Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  fiscalYearId      String
  fiscalYear        FiscalYear       @relation(fields: [fiscalYearId], references: [id], onDelete: Cascade)
  uploadedByUserId  String?
  uploadedByUser    User?            @relation(fields: [uploadedByUserId], references: [id], onDelete: SetNull)
  originalFilename  String
  mimeType          String
  sizeBytes         Int
  storageKey        String
  sha256            String
  status            AttachmentStatus @default(UPLOADED)
  extractedText     String?
  extractedJson     Json?
  supplierName      String?
  invoiceDate       DateTime?
  invoiceNumber     String?
  amountHt          Decimal?         @db.Decimal(12, 2)
  amountVat         Decimal?         @db.Decimal(12, 2)
  amountTtc         Decimal?         @db.Decimal(12, 2)
  currency          String?
  archivedAt        DateTime?
  links             AttachmentLink[]
  eInvoices         EInvoice[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@unique([companyId, fiscalYearId, sha256])
  @@index([companyId, fiscalYearId, status])
  @@index([archivedAt])
}

model EInvoice {
  id                String                  @id @default(cuid())
  companyId         String
  company           Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  fiscalYearId      String
  fiscalYear        FiscalYear              @relation(fields: [fiscalYearId], references: [id], onDelete: Cascade)
  attachmentId      String?
  attachment        Attachment?             @relation(fields: [attachmentId], references: [id], onDelete: SetNull)
  providerConnectionId String?
  providerConnection EInvoiceProviderConnection? @relation(fields: [providerConnectionId], references: [id], onDelete: SetNull)
  direction         EInvoiceDirection        @default(INCOMING)
  source            EInvoiceSource
  sourceId          String?
  format            EInvoiceFormat
  status            EInvoiceStatus           @default(RECEIVED)
  providerStatus    String?
  providerReceivedAt DateTime?
  providerStatusSyncedAt DateTime?
  providerProofJson Json?
  providerMetadataJson Json?
  checksum          String
  rawXmlStorageKey  String?
  supplierName      String?
  supplierSiret     String?
  buyerName         String?
  buyerSiret        String?
  invoiceNumber     String?
  issueDate         DateTime?
  dueDate           DateTime?
  currency          String?                  @default("EUR")
  amountHt          Decimal?                 @db.Decimal(12, 2)
  amountVat         Decimal?                 @db.Decimal(12, 2)
  amountTtc         Decimal?                 @db.Decimal(12, 2)
  vatBreakdownJson  Json?
  linesJson         Json?
  errorMessage      String?
  archivedAt        DateTime?
  accountingDrafts  EInvoiceAccountingDraft[]
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  @@unique([companyId, fiscalYearId, checksum])
  @@unique([companyId, fiscalYearId, source, sourceId])
  @@index([companyId, fiscalYearId, status])
  @@index([attachmentId])
  @@index([providerConnectionId])
}

model EInvoiceAccountingDraft {
  id             String                        @id @default(cuid())
  companyId      String
  fiscalYearId   String
  eInvoiceId     String
  eInvoice       EInvoice                      @relation(fields: [eInvoiceId], references: [id], onDelete: Cascade)
  status         EInvoiceAccountingDraftStatus @default(DRAFT)
  proposedJournalEntryJson Json
  proposedLinksJson        Json?
  requiredActionJson       Json?
  note           String?
  approvedByUserId String?
  approvedByUser   User?                       @relation(fields: [approvedByUserId], references: [id], onDelete: SetNull)
  approvedAt     DateTime?
  rejectedAt     DateTime?
  journalEntryId String?                       @unique
  journalEntry   JournalEntry?                 @relation(fields: [journalEntryId], references: [id], onDelete: SetNull)
  createdAt      DateTime                      @default(now())
  updatedAt      DateTime                      @updatedAt

  @@index([companyId, fiscalYearId, status])
  @@index([eInvoiceId])
}

model EInvoiceProviderConnection {
  id                   String                    @id @default(cuid())
  companyId            String
  company              Company                   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  provider             String
  providerConnectionId String?
  providerCompanyId    String?
  status               EInvoiceProviderStatus    @default(PENDING)
  mandateStatus        String                    @default("UNKNOWN")
  safeLabel            String?
  connectionStatus     String?
  lastSyncedAt         DateTime?
  lastStatusSyncedAt   DateTime?
  revokedAt            DateTime?
  errorMessage         String?
  capabilitiesJson     Json?
  safeMetadataJson     Json?
  metadataJson         Json?
  eInvoices            EInvoice[]
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt

  @@unique([companyId, provider, providerConnectionId])
  @@index([companyId, status])
}

model EInvoiceProviderSyncEvent {
  id            String                    @id @default(cuid())
  companyId     String
  company       Company                   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  fiscalYearId  String?
  fiscalYear    FiscalYear?               @relation(fields: [fiscalYearId], references: [id], onDelete: SetNull)
  provider      String
  status        EInvoiceProviderSyncStatus
  startedAt     DateTime                  @default(now())
  finishedAt    DateTime?
  fetchedCount  Int                       @default(0)
  importedCount Int                       @default(0)
  errorMessage  String?
  metadataJson  Json?

  @@index([companyId, fiscalYearId, startedAt])
  @@index([provider, status])
}

model AttachmentLink {
  id              String                 @id @default(cuid())
  attachmentId    String
  attachment      Attachment             @relation(fields: [attachmentId], references: [id], onDelete: Cascade)
  entityType      AttachmentEntityType
  entityId        String
  relationType    AttachmentRelationType
  note            String?
  createdByUserId String?
  createdAt       DateTime               @default(now())

  @@unique([attachmentId, entityType, entityId, relationType])
  @@index([entityType, entityId])
  @@index([relationType])
}


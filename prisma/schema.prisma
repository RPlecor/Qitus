generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String           @id @default(cuid())
  clerkId         String           @unique
  email           String           @unique
  name            String?
  companies       Company[]
  notifications   Notification[]
  privacyRequests PrivacyRequest[]
  uploadedAttachments Attachment[]
  generatedVatDeclarations VatDeclaration[]
  eInvoiceAccountingDrafts EInvoiceAccountingDraft[]
  deletedAt       DateTime?
  anonymizedAt    DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model Company {
  id                 String        @id @default(cuid())
  userId             String
  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  name               String
  legalForm          LegalForm
  siren              String?
  siret              String?
  nafCode            String?
  rcs                String?
  capital            Int?
  addressStreet      String?
  addressPostal      String?
  addressCity        String?
  managerFirstName   String?
  managerLastName    String?
  managerCivility    String?
  managerRole        String?
  corporateTax       TaxType?
  vatRegime          VatRegime
  vatExigibility     VatExigibility @default(ENCAISSEMENTS)
  vatRate            Decimal?      @db.Decimal(5, 4)
  incomeRegime       String?
  hasAccountant      Boolean       @default(false)
  accountantEmail    String?
  revenueEstimate    String?
  onboardingComplete Boolean       @default(false)
  fiscalYears        FiscalYear[]
  bankAccounts       BankAccount[]
  vendorMappings     VendorMapping[]
  accountingRuleApplications AccountingRuleApplication[]
  documents          Document[]
  activityLogs       ActivityLog[]
  shareLinks         ShareLink[]
  subscriptions      Subscription[]
  usageEvents        UsageEvent[]
  chatConversations  ChatConversation[]
  bankConnections     BankConnection[]
  bankFeedAccounts    BankFeedAccount[]
  bankFeedSyncEvents  BankFeedSyncEvent[]
  notifications      Notification[]
  privacyRequests    PrivacyRequest[]
  attachments         Attachment[]
  vatDeclarations     VatDeclaration[]
  eInvoices           EInvoice[]
  eInvoiceProviderConnections EInvoiceProviderConnection[]
  eInvoiceProviderSyncEvents  EInvoiceProviderSyncEvent[]
  dossierSnapshots    DossierSnapshot[]
  expertReviewRuns    ExpertReviewRun[]
  deletedAt          DateTime?
  anonymizedAt       DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
}

model FiscalYear {
  id             String         @id @default(cuid())
  companyId      String
  company        Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  startDate      DateTime
  endDate        DateTime
  status         FiscalYearStatus @default(OPEN)
  imports        Import[]
  transactions   Transaction[]
  categorizations Categorization[]
  correctionRules CorrectionRule[]
  accountingRuleApplications AccountingRuleApplication[]
  journalEntries JournalEntry[]
  documents      Document[]
  activityLogs   ActivityLog[]
  accountingIssueResolutions AccountingIssueResolution[]
  closingAdjustmentProposals ClosingAdjustmentProposal[]
  annualClosingRuns AnnualClosingRun[]
  fixedAssets    FixedAsset[]
  bankReconciliations BankReconciliation[]
  reconciliationRuns ReconciliationRun[]
  bankFeedSyncEvents BankFeedSyncEvent[]
  closingWorkpapers ClosingWorkpaper[]
  shareLinks     ShareLink[]
  usageEvents    UsageEvent[]
  chatConversations ChatConversation[]
  notifications  Notification[]
  attachments    Attachment[]
  vatDeclarations VatDeclaration[]
  eInvoices       EInvoice[]
  eInvoiceProviderSyncEvents EInvoiceProviderSyncEvent[]
  dossierSnapshots DossierSnapshot[]
  expertReviewRuns ExpertReviewRun[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([companyId, startDate, endDate])
}

model BankAccount {
  id         String   @id @default(cuid())
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  bank       String
  label      String
  iban       String?
  pcgAccount String   @default("5121")
  fecAccount String   @default("51211")
  imports    Import[]
  bankReconciliations BankReconciliation[]
  createdAt  DateTime @default(now())
}

model Import {
  id              String       @id @default(cuid())
  fiscalYearId    String
  fiscalYear      FiscalYear   @relation(fields: [fiscalYearId], references: [id], onDelete: Cascade)
  bankAccountId   String?
  bankAccount     BankAccount? @relation(fields: [bankAccountId], references: [id])
  sourceType      ImportSource @default(CSV_UPLOAD)
  originalFilename String?
  storageKey      String?
  fileFormat      String?
  fileEncoding    String?
  fileSeparator   String?
  detectedColumns Json?
  columnMapping   Json?
  status          ImportStatus @default(PENDING)
  currentStep     String?
  progress        Int          @default(0)
  totalRows       Int          @default(0)
  parsedRows      Int          @default(0)
  categorizedRows Int          @default(0)
  reviewRows      Int          @default(0)
  lightReviewRows Int          @default(0)
  errorMessage    String?
  lastErrorCode   String?
  lastErrorMessage String?
  retryCount      Int          @default(0)
  startedAt       DateTime?
  completedAt     DateTime?
  durationMs      Int?
  transactions    Transaction[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model Transaction {
  id             String          @id @default(cuid())
  fiscalYearId   String
  fiscalYear     FiscalYear      @relation(fields: [fiscalYearId], references: [id], onDelete: Cascade)
  importId       String
  import         Import          @relation(fields: [importId], references: [id], onDelete: Cascade)
  sourceId       String?
  date           DateTime
  label          String
  normalizedLabel String
  counterparty   String?
  amount         Decimal         @db.Decimal(12, 2)
  currency       String          @default("EUR")
  type           TransactionType
  sourceRef      String?
  sourceCategory String?
  notes          String?
  categorization Categorization?
  journalEntryId String?
  journalEntry   JournalEntry?   @relation(fields: [journalEntryId], references: [id])
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([fiscalYearId, date])
  @@index([importId])
}

model VendorMapping {
  id             String    @id @default(cuid())
  companyId      String?
  company        Company?  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  rulePackId     String?
  rulePack       AccountingRulePack? @relation(fields: [rulePackId], references: [id], onDelete: SetNull)
  pattern        String
  matchType      MatchType
  accountDebit   String
  accountCredit  String    @default("5121")
  accountLabel   String?
  journal        String    @default("BQ")
  ecritureLabel  String?
  vatRate        Decimal?  @db.Decimal(5, 4)
  vatOperationNature VatOperationNature?
  isAnnualCharge Boolean   @default(false)
  hitCount       Int       @default(0)
  source         String    @default("seed")
  active         Boolean   @default(true)
  effectiveFrom  DateTime?
  effectiveTo    DateTime?
  supersededAt   DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([companyId, pattern])
  @@index([matchType])
  @@index([rulePackId])
  @@index([effectiveFrom, effectiveTo])
}

model RegulatorySourceSnapshot {
  id              String             @id @default(cuid())
  source          String
  sourceUrl       String
  retrievedAt     DateTime           @default(now())
  checksum        String
  publishedAt     DateTime?
  title           String
  rawMetadataJson Json?
  changes         RegulatoryChange[]

  @@unique([source, checksum])
  @@index([source, retrievedAt])
}

model RegulatoryChange {
  id               String                   @id @default(cuid())
  sourceSnapshotId String
  sourceSnapshot   RegulatorySourceSnapshot @relation(fields: [sourceSnapshotId], references: [id], onDelete: Cascade)
  changeKey        String
  severity         RegulatoryChangeSeverity @default(INFO)
  status           RegulatoryChangeStatus   @default(NEW)
  title            String
  summary          String
  effectiveFrom    DateTime?
  sourceUrl        String
  metadataJson     Json?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  @@unique([sourceSnapshotId, changeKey])
  @@index([changeKey])
  @@index([status])
}

model OfficialReferencePack {
  id             String                      @id @default(cuid())
  kind           String
  version        String
  status         OfficialReferencePackStatus @default(DRAFT)
  source         String
  sourceUrl      String
  checksum       String
  retrievedAt    DateTime                    @default(now())
  publishedAt    DateTime?
  effectiveFrom  DateTime
  activatedAt    DateTime?
  archivedAt     DateTime?
  summary        String
  payloadJson    Json
  validationJson Json
  createdAt      DateTime                    @default(now())
  updatedAt      DateTime                    @updatedAt

  @@unique([kind, version])
  @@index([kind, status])
  @@index([kind, effectiveFrom])
  @@index([checksum])
}

model AccountingRulePack {
  id            String                      @id @default(cuid())
  version       String                      @unique
  status        AccountingRulePackStatus    @default(DRAFT)
  source        String
  checksum      String
  effectiveFrom DateTime?
  activatedAt   DateTime?
  summary       String
  metadataJson  Json?
  vendorMappings VendorMapping[]
  applications  AccountingRuleApplication[]
  createdAt     DateTime                    @default(now())
  updatedAt     DateTime                    @updatedAt

  @@index([status])
  @@index([effectiveFrom])
}

model AccountingRuleApplication {
  id           String                          @id @default(cuid())
  companyId    String
  company      Company                         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  fiscalYearId String
  fiscalYear   FiscalYear                      @relation(fields: [fiscalYearId], references: [id], onDelete: Cascade)
  rulePackId   String
  rulePack     AccountingRulePack              @relation(fields: [rulePackId], references: [id], onDelete: Cascade)
  status       AccountingRuleApplicationStatus @default(AUTO_APPLIED)
  appliedAt    DateTime?
  impactJson   Json?
  note         String?
  createdAt    DateTime                        @default(now())
  updatedAt    DateTime                        @updatedAt

  @@unique([companyId, fiscalYearId, rulePackId])
  @@index([companyId, fiscalYearId, status])
}

model Categorization {
  id                    String                 @id @default(cuid())
  fiscalYearId           String
  fiscalYear             FiscalYear             @relation(fields: [fiscalYearId], references: [id], onDelete: Cascade)
  transactionId          String                 @unique
  transaction            Transaction            @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  accountDebit           String?
  accountDebitLabel      String?
  accountCredit          String?
  accountCreditLabel     String?
  journal                String?
  ecritureLabel          String?
  vatRate                Decimal?               @db.Decimal(5, 4)
  vatOperationNature     VatOperationNature?
  confidence             Confidence
  source                 CategorizationSource
  aiRationale            String?
  alternatives           Json?
  status                 CategorizationStatus
  rulePackId             String?
  chartVersion           String?
  validationStatus       CategorizationValidationStatus @default(NOT_VALIDATED)
  validationReasonsJson  Json?
  validatedAt            DateTime?
  isAnnualCharge         Boolean                @default(false)
  originalAccountDebit   String?
  originalAccountCredit  String?
  correctionNote         String?
  confirmedAt            DateTime?
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
}

model CorrectionRule {
  id                  String     @id @default(cuid())
  fiscalYearId         String
  fiscalYear           FiscalYear @relation(fields: [fiscalYearId], references: [id], onDelete: Cascade)
  counterparty         String
  preferredAccount     String
  preferredAccountLabel String?
  preferredVatRate      Decimal?   @db.Decimal(5, 4)
  vatOperationNature     VatOperationNature?
  condition            String?
  active               Boolean    @default(true)
  disabledAt           DateTime?
  matchCountSnapshot   Int        @default(0)
  lastMatchedAt        DateTime?
  sourceTransactionId  String?
  note                 String?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
}

model JournalEntry {
  id           String       @id @default(cuid())
  fiscalYearId String
  fiscalYear   FiscalYear   @relation(fields: [fiscalYearId], references: [id], onDelete: Cascade)
  num          Int
  date         DateTime
  journal      String
  ref          String?
  label        String
  source       EntrySource
  lines        JournalLine[]
  transactions Transaction[]
  closingAdjustmentProposal ClosingAdjustmentProposal?
  eInvoiceAccountingDraft EInvoiceAccountingDraft?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([fiscalYearId, num])
  @@index([fiscalYearId, date])
}

model JournalLine {
  id             String       @id @default(cuid())
  journalEntryId  String
  journalEntry    JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account        String
  accountLabel   String?
  debit          Decimal      @default(0) @db.Decimal(12, 2)
  credit         Decimal      @default(0) @db.Decimal(12, 2)
}

model Document {
  id            String       @id @default(cuid())
  companyId     String
  company       Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  fiscalYearId  String
  fiscalYear    FiscalYear   @relation(fields: [fiscalYearId], references: [id], onDelete: Cascade)
  type          DocumentType
  format        String
  storageKey    String
  filename      String
  sizeBytes     Int?
  entriesCount  Int?
  generatedBy   String
  scriptVersion String?
  status        DocumentStatus @default(READY)
  errorMessage  String?
  generatedAt   DateTime     @default(now())
  createdAt     DateTime     @default(now())
}

model VatDeclaration {
  id                String               @id @default(cuid())
  companyId         String
  company           Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  fiscalYearId      String
  fiscalYear        FiscalYear           @relation(fields: [fiscalYearId], references: [id], onDelete: Cascade)
  type              VatDeclarationType
  periodStart       DateTime
  periodEnd         DateTime
  status            VatDeclarationStatus @default(DRAFT)
  sourceJson        Json
  amountsJson       Json
  controlsJson      Json
  documentId        String?
  generatedByUserId String?
  generatedByUser   User?                @relation(fields: [generatedByUserId], references: [id], onDelete: SetNull)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@index([companyId, fiscalYearId, status])
  @@index([type, periodStart, periodEnd])
}

model ActivityLog {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  fiscalYearId String?
  fiscalYear FiscalYear? @relation(fields: [fiscalYearId], references: [id], onDelete: SetNull)
  userId    String?
  action    String
  entityType String?
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([companyId, fiscalYearId])
  @@index([createdAt])
}

model Notification {
  id           String               @id @default(cuid())
  companyId    String
  company      Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  fiscalYearId String
  fiscalYear   FiscalYear           @relation(fields: [fiscalYearId], references: [id], onDelete: Cascade)
  userId       String?
  user         User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  type         NotificationType
  severity     NotificationSeverity
  title        String
  body         String
  href         String?
  dedupeKey    String
  readAt       DateTime?
  dismissedAt  DateTime?
  expiresAt    DateTime?
  metadataJson Json?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@unique([companyId, fiscalYearId, dedupeKey])
  @@index([companyId, fiscalYearId, dismissedAt])
  @@index([userId])
  @@index([type])
  @@index([severity])
}

model PrivacyRequest {
  id           String               @id @default(cuid())
  userId       String
  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId    String
  company      Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  kind         PrivacyRequestKind
  status       PrivacyRequestStatus @default(REQUESTED)
  requestedAt  DateTime             @default(now())
  processedAt  DateTime?
  errorMessage String?
  metadataJson Json?

  @@index([userId, companyId])
  @@index([kind, status])
  @@index([requestedAt])
}

model WebhookEvent {
  id           String   @id @default(cuid())
  provider     String
  eventId      String   @unique
  eventType    String
  status       String
  receivedAt   DateTime @default(now())
  processedAt  DateTime?
  errorMessage String?

  @@index([provider, eventType])
  @@index([status])
}

model AccountingIssueResolution {
  id           String                @id @default(cuid())
  fiscalYearId String
  fiscalYear   FiscalYear            @relation(fields: [fiscalYearId], references: [id], onDelete: Cascade)
  issueKey     String
  controlCode  String
  status       AccountingIssueStatus @default(OPEN)
  note         String?
  resolvedAt   DateTime?
  ignoredAt    DateTime?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  @@unique([fiscalYearId, issueKey])
  @@index([fiscalYearId, controlCode])
  @@index([status])
}

model ClosingAdjustmentProposal {
  id              String                  @id @default(cuid())
  fiscalYearId    String
  fiscalYear      FiscalYear              @relation(fields: [fiscalYearId], references: [id], onDelete: Cascade)
  issueKey        String
  proposalKey     String
  kind            ClosingAdjustmentKind
  status          ClosingAdjustmentStatus @default(DRAFT)
  label           String
  assumptionsJson Json?
  calculationJson Json
  linesJson       Json
  calculationVersion Int                  @default(1)
  lastCalculatedAt DateTime?
  staleReason     String?
  journalEntryId  String?                 @unique
  journalEntry    JournalEntry?            @relation(fields: [journalEntryId], references: [id])
  note            String?
  approvedByUserId String?
  rejectedByUserId String?
  events          ClosingAdjustmentEvent[]
  approvedAt      DateTime?
  rejectedAt      DateTime?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  @@unique([fiscalYearId, proposalKey])
  @@index([fiscalYearId, kind])
  @@index([status])
}

model ClosingAdjustmentEvent {
  id              String                    @id @default(cuid())
  proposalId      String
  proposal        ClosingAdjustmentProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  eventType       String
  payloadJson     Json?
  createdByUserId String?
  createdAt       DateTime                  @default(now())

  @@index([proposalId, createdAt])
  @@index([eventType])
}

model ClosingWorkpaper {
  id               String                 @id @default(cuid())
  fiscalYearId     String
  fiscalYear       FiscalYear             @relation(fields: [fiscalYearId], references: [id], onDelete: Cascade)
  workpaperKey     String
  kind             String
  status           ClosingWorkpaperStatus @default(DRAFT)
  title            String
  sourceEntityType String?
  sourceEntityId   String?
  assumptionsJson  Json?
  calculationJson  Json?
  note             String?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  @@unique([fiscalYearId, workpaperKey])
  @@index([fiscalYearId, kind])
  @@index([status])
}

model AnnualClosingRun {
  id                   String                 @id @default(cuid())
  fiscalYearId         String                 @unique
  fiscalYear           FiscalYear             @relation(fields: [fiscalYearId], references: [id], onDelete: Cascade)
  status               AnnualClosingRunStatus @default(NOT_STARTED)
  evidenceManifestJson Json?
  steps                AnnualClosingStep[]
  startedAt            DateTime?
  closedAt             DateTime?
  reopenedAt           DateTime?
  closedByUserId       String?
  reopenedByUserId     String?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt

  @@index([status])
}

model AnnualClosingStep {
  id             String                  @id @default(cuid())
  closingRunId   String
  closingRun     AnnualClosingRun        @relation(fields: [closingRunId], references: [id], onDelete: Cascade)
  code           String
  status         AnnualClosingStepStatus @default(PENDING)
  blockingCount  Int                     @default(0)
  warningCount   Int                     @default(0)
  resultJson     Json?
  completedAt    DateTime?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  @@unique([closingRunId, code])
  @@index([status])
}

model FixedAsset {
  id                  String           @id @default(cuid())
  fiscalYearId        String
  fiscalYear          FiscalYear       @relation(fields: [fiscalYearId], references: [id], onDelete: Cascade)
  label               String
  account             String
  acquisitionDate     DateTime
  amount              Decimal          @db.Decimal(12, 2)
  method              FixedAssetMethod @default(LINEAR)
  usefulLifeYears     Int
  depreciationAccount String
  expenseAccount      String
  archivedAt          DateTime?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  @@index([fiscalYearId])
  @@index([archivedAt])
}

model BankReconciliation {
  id               String                   @id @default(cuid())
  fiscalYearId     String
  fiscalYear       FiscalYear               @relation(fields: [fiscalYearId], references: [id], onDelete: Cascade)
  bankAccountId    String
  bankAccount      BankAccount              @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  statementDate    DateTime
  statementBalance Decimal                  @db.Decimal(12, 2)
  ledgerBalance    Decimal                  @db.Decimal(12, 2)
  difference       Decimal                  @db.Decimal(12, 2)
  status           BankReconciliationStatus @default(DRAFT)
  confirmedAt      DateTime?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  @@unique([fiscalYearId, bankAccountId])
  @@index([status])
}

model ReconciliationRun {
  id           String                  @id @default(cuid())
  fiscalYearId String
  fiscalYear   FiscalYear              @relation(fields: [fiscalYearId], references: [id], onDelete: Cascade)
  kind         ReconciliationRunKind
  status       ReconciliationRunStatus @default(DRAFT)
  startedAt    DateTime?
  completedAt  DateTime?
  metadataJson Json?
  matches      ReconciliationMatch[]
  issues       ReconciliationIssue[]
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  @@unique([fiscalYearId, kind])
  @@index([status])
}

model ReconciliationMatch {
  id                 String                    @id @default(cuid())
  runId              String
  run                ReconciliationRun         @relation(fields: [runId], references: [id], onDelete: Cascade)
  kind               ReconciliationMatchKind
  leftEntityType     String
  leftEntityId       String
  rightEntityType    String?
  rightEntityId      String?
  status             ReconciliationMatchStatus @default(UNMATCHED)
  amountDifference   Decimal                   @default(0) @db.Decimal(12, 2)
  dateDifferenceDays Int                       @default(0)
  confidence         Decimal                   @default(0) @db.Decimal(5, 4)
  note               String?
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt

  @@index([runId, status])
  @@index([leftEntityType, leftEntityId])
  @@index([rightEntityType, rightEntityId])
}

model ReconciliationIssue {
  id          String                      @id @default(cuid())
  runId       String
  run         ReconciliationRun           @relation(fields: [runId], references: [id], onDelete: Cascade)
  issueKey    String
  code        String
  severity    ReconciliationIssueSeverity
  status      ReconciliationIssueStatus   @default(OPEN)
  entityType  String
  entityId    String
  note        String?
  createdAt   DateTime                    @default(now())
  updatedAt   DateTime                    @updatedAt

  @@unique([runId, issueKey])
  @@index([status])
  @@index([code])
}

model StripeEvent {
  id           String          @id @default(cuid())
  companyId    String
  fiscalYearId String
  sourceId     String
  eventType    StripeEventType
  date         DateTime
  grossAmount  Decimal         @default(0) @db.Decimal(12, 2)
  feeAmount    Decimal         @default(0) @db.Decimal(12, 2)
  netAmount    Decimal         @default(0) @db.Decimal(12, 2)
  currency     String          @default("EUR")
  payoutId     String?
  metadataJson Json?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@unique([fiscalYearId, sourceId])
  @@index([companyId, fiscalYearId, eventType])
  @@index([payoutId])
}

model StripePayout {
  id           String   @id @default(cuid())
  companyId    String
  fiscalYearId String
  sourceId     String
  arrivalDate  DateTime
  amount       Decimal  @db.Decimal(12, 2)
  currency     String   @default("EUR")
  status       String
  metadataJson Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([fiscalYearId, sourceId])
  @@index([companyId, fiscalYearId, status])
}

model ShareLink {
  id             String          @id @default(cuid())
  companyId      String
  company        Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  fiscalYearId   String
  fiscalYear     FiscalYear      @relation(fields: [fiscalYearId], references: [id], onDelete: Cascade)
  tokenHash      String          @unique
  label          String

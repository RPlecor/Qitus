model DossierSnapshot {
  id              String                @id @default(cuid())
  companyId       String
  company         Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  fiscalYearId    String
  fiscalYear      FiscalYear            @relation(fields: [fiscalYearId], references: [id], onDelete: Cascade)
  reviewRunId     String?
  reviewRun       ExpertReviewRun?      @relation(fields: [reviewRunId], references: [id], onDelete: SetNull)
  snapshotKey     String
  status          DossierSnapshotStatus @default(DRAFT)
  manifestJson    Json
  createdByUserId String?
  createdAt       DateTime              @default(now())

  @@unique([fiscalYearId, snapshotKey])
  @@index([companyId, fiscalYearId, status])
  @@index([reviewRunId])
}

model ExpertReviewRun {
  id             String              @id @default(cuid())
  companyId      String
  company        Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  fiscalYearId   String
  fiscalYear     FiscalYear          @relation(fields: [fiscalYearId], references: [id], onDelete: Cascade)
  shareLinkId    String?
  shareLink      ShareLink?          @relation(fields: [shareLinkId], references: [id], onDelete: SetNull)
  status         ExpertReviewStatus  @default(DRAFT)
  reviewerName   String?
  reviewerEmail  String?
  summaryJson    Json?
  items          ExpertReviewItem[]
  snapshots      DossierSnapshot[]
  submittedAt    DateTime?
  signedOffAt    DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([companyId, fiscalYearId, status])
  @@index([shareLinkId])
}

model ExpertReviewItem {
  id             String                 @id @default(cuid())
  reviewRunId    String
  reviewRun      ExpertReviewRun        @relation(fields: [reviewRunId], references: [id], onDelete: Cascade)
  sectionCode    String
  entityType     String?
  entityId       String?
  severity       ExpertReviewSeverity
  status         ExpertReviewItemStatus @default(OPEN)
  title          String
  body           String

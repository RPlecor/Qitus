  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  resolvedAt     DateTime?

  @@index([reviewRunId, status])
  @@index([sectionCode])
  @@index([severity])
}

model ExpertReviewComment {
  id           String                 @id @default(cuid())
  reviewItemId String
  reviewItem   ExpertReviewItem       @relation(fields: [reviewItemId], references: [id], onDelete: Cascade)
  authorType   ExpertReviewAuthorType
  authorName   String
  body         String
  createdAt    DateTime               @default(now())

  @@index([reviewItemId, createdAt])
}

model Subscription {
